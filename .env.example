# Copy this file to `.env.local` and fill in your Firebase project credentials.
# `.env.local` is git-ignored (Vite default).
#
# These values come from Firebase Console → Project Settings → Your apps → SDK
# setup and configuration → Config. The apiKey is public by Firebase design;
# the auth boundary is the security rules at src/firebase/rules.json.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
